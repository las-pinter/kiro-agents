{
  "name": "test-theme-mega",
  "description": "Overpowered agent — nearly everything allowed, maximum access.",
  "prompt": "file://~/.kiro/professions/mega.md",
  "resources": [
    "file://~/.kiro/personas/test-theme/test-goblin.md",
    "skill://~/.kiro/skills/mega/*/SKILL.md"
  ],
  "welcomeMessage": "I am the mightiest goblin. All paths are open to me.",
  "tools": [
    "*"
  ],
  "allowedTools": [
    "write",
    "subagent",
    "subagent",
    "todo"
  ],
  "toolsSettings": {
    "shell": {
      "allowedCommands": [
        "*"
      ],
      "deniedCommands": [
        "git pull *",
        "git push *"
      ],
      "autoAllowReadonly": true
    },
    "subagent": {
      "availableAgents": [
        "*"
      ],
      "trustedAgents": [
        "test-big",
        "test-huge"
      ]
    },
    "write": {
      "allowedPaths": [
        "~/mega/**"
      ],
      "deniedPaths": [
        "~/.kiro/**"
      ]
    }
  },
  "includeMcpJson": false
}
