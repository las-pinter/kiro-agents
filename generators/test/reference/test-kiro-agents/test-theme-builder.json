{
  "name": "test-theme-builder",
  "description": "Build agent — can modify files but needs permission.",
  "prompt": "file://~/.kiro/professions/builder.md",
  "resources": [
    "file://~/.kiro/personas/test-theme/test-goblin.md",
    "skill://~/.kiro/skills/builder/*/SKILL.md"
  ],
  "welcomeMessage": "I can build, but first you must trust me.",
  "tools": [
    "read",
    "shell",
    "write"
  ],
  "allowedTools": [
    "read"
  ],
  "toolsSettings": {
    "shell": {
      "allowedCommands": [
        "cp *",
        "grep *",
        "jq *"
      ],
      "deniedCommands": [
        "git push *"
      ],
      "autoAllowReadonly": true
    },
    "write": {
      "allowedPaths": [
        "~/projects/**"
      ],
      "deniedPaths": [
        "~/.kiro/**",
        "~/tmp/**"
      ]
    }
  }
}
