{
  "name": "test-theme-orchestrator",
  "description": "Orchestrator test agent",
  "prompt": "file://~/.kiro/professions/orchestrator.md",
  "resources": [
    "file://~/.kiro/personas/test-theme/test-goblin.md",
    "skill://~/.kiro/skills/orchestrator/*/SKILL.md"
  ],
  "welcomeMessage": "Hurrdurr.",
  "tools": [
    "*"
  ],
  "allowedTools": [
    "code",
    "glob",
    "grep",
    "introspect",
    "read",
    "subagent",
    "thinking",
    "todo"
  ],
  "toolsSettings": {
    "shell": {
      "allowedCommands": [
        "awk *",
        "cat *",
        "date *",
        "diff *",
        "find *",
        "git *",
        "grep *",
        "head *",
        "jq *",
        "ls *",
        "pwd",
        "sed *",
        "sort *",
        "tail *",
        "touch *",
        "tr *",
        "uniq *",
        "wc *",
        "which *",
        "xargs *"
      ],
      "deniedCommands": [
        "git pull *",
        "git push *"
      ],
      "autoAllowReadonly": true
    },
    "subagent": {
      "availableAgents": [
        "*"
      ],
      "trustedAgents": [
        "test-theme-*"
      ]
    },
    "write": {
      "allowedPaths": [
        "~/agent-notes/orchestrator/**"
      ]
    }
  }
}
