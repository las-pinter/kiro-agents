{
  "name": "test-theme-admin",
  "description": "Admin agent — full write, shell, and can delegate to other agents.",
  "prompt": "file://~/.kiro/professions/admin.md",
  "resources": [
    "file://~/.kiro/personas/test-theme/test-goblin.md",
    "skill://~/.kiro/skills/admin/*/SKILL.md"
  ],
  "welcomeMessage": "Open sesame. I have the keys and the authority.",
  "tools": [
    "read",
    "shell",
    "subagent",
    "todo",
    "write"
  ],
  "allowedTools": [
    "read",
    "subagent",
    "todo"
  ],
  "toolsSettings": {
    "shell": {
      "allowedCommands": [
        "cp *",
        "git *",
        "mv *"
      ]
    },
    "subagent": {
      "availableAgents": [
        "*"
      ],
      "trustedAgents": [
        "test-theme-*"
      ]
    },
    "write": {
      "allowedPaths": [
        "~/workspace/**"
      ]
    }
  },
  "includeMcpJson": false
}
