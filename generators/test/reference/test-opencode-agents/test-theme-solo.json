{
  "test-theme-solo": {
    "description": "Minimal agent — only read, grep, glob.",
    "mode": "all",
    "temperature": 0.4,
    "prompt": "{file:~/.config/opencode/professions/solo.md}{file:~/.config/opencode/personas/test-theme/test-goblin.md}",
    "permission": {
      "*": "deny",
      "external_directory": {
        "*": "ask",
        "~/.config/opencode/**": "allow"
      },
      "read": "allow",
      "grep": "allow",
      "glob": "allow",
      "skill": {
        "*": "deny",
        "solo-skill": "allow"
      }
    }
  }
}
