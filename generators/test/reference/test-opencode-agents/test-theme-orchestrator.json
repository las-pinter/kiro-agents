{
  "test-theme-orchestrator": {
    "description": "Orchestrator test agent",
    "mode": "primary",
    "temperature": 0.6,
    "top_p": 0.95,
    "prompt": "{file:~/.config/opencode/professions/orchestrator.md}{file:~/.config/opencode/personas/test-theme/test-goblin.md}",
    "permission": {
      "*": "ask",
      "external_directory": {
        "*": "ask",
        "~/.config/opencode/**": "allow",
        "~/agent-notes/orchestrator/**": "allow"
      },
      "edit": {
        "*": "ask",
        "~/agent-notes/orchestrator/**": "allow"
      },
      "glob": "allow",
      "grep": "allow",
      "question": "allow",
      "read": "allow",
      "bash": {
        "*": "ask",
        "awk *": "allow",
        "cat *": "allow",
        "date *": "allow",
        "diff *": "allow",
        "find *": "allow",
        "git *": "allow",
        "grep *": "allow",
        "head *": "allow",
        "jq *": "allow",
        "ls *": "allow",
        "pwd": "allow",
        "sed *": "allow",
        "sort *": "allow",
        "tail *": "allow",
        "touch *": "allow",
        "tr *": "allow",
        "uniq *": "allow",
        "wc *": "allow",
        "which *": "allow",
        "xargs *": "allow",
        "git push *": "deny",
        "git pull *": "deny"
      },
      "task": {
        "*": "ask",
        "test-theme-*": "allow"
      },
      "todowrite": "allow",
      "write": {
        "*": "ask",
        "~/agent-notes/orchestrator/**": "allow"
      },
      "skill": {
        "*": "ask"
      }
    }
  }
}
