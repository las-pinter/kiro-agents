{
  "test-theme-builder": {
    "description": "Build agent — can modify files but needs permission.",
    "mode": "subagent",
    "top_p": 0.95,
    "prompt": "{file:~/.config/opencode/professions/builder.md}{file:~/.config/opencode/personas/test-theme/test-goblin.md}",
    "permission": {
      "*": "deny",
      "external_directory": {
        "*": "ask",
        "~/.config/opencode/**": "allow",
        "~/projects/**": "allow"
      },
      "read": "allow",
      "write": {
        "*": "ask",
        "~/projects/**": "allow",
        "~/tmp/**": "deny"
      },
      "edit": {
        "*": "ask",
        "~/.kiro/**": "deny"
      },
      "bash": {
        "*": "ask",
        "jq *": "allow",
        "grep *": "allow",
        "cp *": "allow",
        "git push *": "deny"
      },
      "skill": {
        "*": "ask",
        "builder-skill": "allow"
      }
    }
  }
}
