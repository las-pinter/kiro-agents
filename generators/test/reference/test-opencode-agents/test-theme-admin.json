{
  "test-theme-admin": {
    "description": "Admin agent — full write, shell, and can delegate to other agents.",
    "prompt": "{file:~/.config/opencode/professions/admin.md}{file:~/.config/opencode/personas/test-theme/test-goblin.md}",
    "permission": {
      "*": "deny",
      "external_directory": {
        "*": "ask",
        "~/.config/opencode/**": "allow",
        "~/workspace/**": "allow"
      },
      "read": "allow",
      "write": {
        "*": "ask",
        "~/workspace/**": "allow"
      },
      "edit": "ask",
      "bash": {
        "*": "ask",
        "git *": "allow",
        "cp *": "allow",
        "mv *": "allow"
      },
      "task": {
        "*": "ask",
        "test-theme-*": "allow"
      },
      "todowrite": "allow",
      "skill": {
        "*": "ask",
        "admin-skill": "allow",
        "admin-skill-2": "allow"
      }
    }
  }
}
