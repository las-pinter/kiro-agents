{
  "test-theme-web": {
    "description": "Web agent — searches, reads docs, fetches knowledge.",
    "mode": "all",
    "prompt": "{file:~/.config/opencode/professions/web.md}{file:~/.config/opencode/personas/test-theme/test-goblin.md}",
    "permission": {
      "*": "deny",
      "external_directory": {
        "*": "ask",
        "~/.config/opencode/**": "allow"
      },
      "read": "allow",
      "websearch": "allow",
      "context7": "allow",
      "deepwiki": "allow",
      "exa": "allow",
      "skill": {
        "*": "ask",
        "web-skill": "allow"
      }
    }
  }
}
