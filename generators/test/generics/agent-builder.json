{
  "$schema": "../../../agents-generic/schema-agent.json",
  "profession": "builder",
  "tools": {
    "default": "deny",
    "read": "allow",
    "write": {
      "default": "ask",
      "~/projects/**": "allow",
      "~/tmp/**": "deny"
    },
    "edit": {
      "default": "ask",
      "~/.kiro/**": "deny"
    },
    "shell": {
      "default": "ask",
      "jq *": "allow",
      "grep *": "allow",
      "cp *": "allow",
      "git push *": "deny",
      "config": {
        "autoAllowReadonly": true
      }
    }
  },
  "skills": {
    "default": "ask"
  },
  "config": {
    "mode": "subagent",
    "top_p": 0.95
  }
}
