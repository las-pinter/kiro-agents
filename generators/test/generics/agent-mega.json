{
  "$schema": "../../../agents-generic/schema-agent.json",
  "profession": "mega",
  "tools": {
    "default": "allow",
    "write": {
      "default": "ask",
      "~/mega/**": "allow",
      "~/.kiro/**": "deny"
    },
    "edit": "allow",
    "shell": {
      "default": "ask",
      "*": "allow",
      "git push *": "deny",
      "git pull *": "deny",
      "config": {
        "autoAllowReadonly": true
      }
    },
    "subagent": {
      "default": "ask",
      "test-big": "allow",
      "test-huge": "allow"
    },
    "todo": "allow"
  },
  "skills": {
    "default": "ask"
  },
  "config": {
    "includeMcpJson": false
  }
}