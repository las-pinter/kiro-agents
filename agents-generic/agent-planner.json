{
  "$schema": "./schema-agent.json",
  "profession": "planner",
  "tools": {
    "default": "deny",
    "code": "allow",
    "glob": "allow",
    "grep": "allow",
    "read": "allow",
    "shell": {
      "config": {
        "autoAllowReadonly": true
      },
      "default": "ask",
      "awk *": "allow",
      "cat *": "allow",
      "cat *>*": "ask",
      "date *": "allow",
      "diff *": "allow",
      "find * -name *": "allow",
      "find * -type *": "allow",
      "git status": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "jq *": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "sort *": "allow",
      "tail *": "allow",
      "tr *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "which *": "allow",
      "git push *": "deny",
      "git pull *": "deny",
      "find * -exec *": "deny",
      "sed -i *": "ask",
      "xargs *": "ask"
    },
    "subagent": {
      "default": "deny",
      "{{THEME}}-researcher": "allow"
    },
    "write": {
      "default": "ask",
      "~/agent-notes/planner/**": "allow"
    }
  },
  "skills": {
    "default": "ask"
  },
  "config": {
    "mode": "all",
    "temperature": 0.1,
    "top_p": 0.95
  }
}
