{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema-agent.json",
  "$defs": {
    "permissionValue": {
      "description": "A simple permission string.",
      "type": "string",
      "enum": [
        "allow",
        "ask",
        "deny"
      ]
    },
    "permissionMap": {
      "description": "A permission that is either a simple string or an object with a required default and path-based overrides.",
      "oneOf": [
        {
          "$ref": "#/$defs/permissionValue"
        },
        {
          "type": "object",
          "required": [
            "default"
          ],
          "properties": {
            "default": {
              "$ref": "#/$defs/permissionValue"
            },
            "config": {
              "description": "Configuration.",
              "type": "object",
              "additionalProperties": {
                "type": "boolean"
              }
            }
          },
          "additionalProperties": {
            "$ref": "#/$defs/permissionValue"
          }
        }
      ]
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profession"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "profession": {
      "type": "string"
    },
    "tools": {
      "description": "Per-tool permission settings.",
      "type": "object",
      "properties": {
        "default": {
          "$ref": "#/$defs/permissionValue"
        }
      },
      "additionalProperties": {
        "$ref": "#/$defs/permissionMap"
      }
    },
    "skills": {
      "description": "Per-skill permission settings.",
      "type": "object",
      "required": [
        "default"
      ],
      "properties": {
        "default": {
          "$ref": "#/$defs/permissionValue"
        }
      },
      "additionalProperties": {
        "$ref": "#/$defs/permissionMap"
      }
    },
    "config": {
      "description": "General configuration settings.",
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    }
  }
}