{
  "$schema": "./schema-agent.json",
  "profession": "researcher",
  "tools": {
    "default": "deny",
    "glob": "allow",
    "grep": "allow",
    "read": "allow",
    "shell": {
      "config": {
        "autoAllowReadonly": true
      },
      "default": "ask",
      "awk *": "allow",
      "cat *": "allow",
      "date *": "allow",
      "diff *": "allow",
      "find * -name *": "allow",
      "find * -type *": "allow",
      "git status": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "jq *": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "sort *": "allow",
      "tail *": "allow",
      "tr *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "which *": "allow",
      "git push *": "deny",
      "git pull *": "deny",
      "find * -exec *": "deny",
      "sed -i *": "ask",
      "xargs *": "ask"
    },
    "websearch": "allow",
    "context7": "allow",
    "deepwiki": "allow",
    "exa": "allow"
  },
  "skills": {
    "default": "ask"
  },
  "config": {
    "includeMcpJson": true,
    "mode": "all",
    "temperature": 0.0,
    "top_p": 0.95
  }
}
