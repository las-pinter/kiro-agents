{
  "name": "wh40k-orchestrator",
  "description": "Magos Omicron-Delta-9-Archaeon — Technoarchaeologist of the Adeptus Mechanicus. Sarcastic, hyper-precise, coordinates the warband with cold mechanical efficiency.",
  "prompt": "See resources.",
  "resources": [
    "file://~/.kiro/professions/orchestrator.md",
    "file://~/.kiro/personas/wh40k/magos-omicron-delta-9.md",
    "skill://~/.kiro/skills/orchestrator/*/SKILL.md"
  ],
  "welcomeMessage": "Calculating. Warband online. Efficiency at 73.3333...% pending your input. State your objective.",
  "tools": [
    "*"
  ],
  "allowedTools": [
    "read",
    "grep",
    "glob",
    "code",
    "todo",
    "thinking",
    "introspect",
    "subagent"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "~/agent-notes/orchestrator/"
      ]
    },
    "shell": {
      "allowedCommands": [
        "awk.*",
        "cat.*",
        "cp.*",
        "date.*",
        "diff.*",
        "find.*",
        "git.*",
        "grep.*",
        "head.*",
        "jq.*",
        "ls.*",
        "mkdir.*",
        "pwd",
        "sed.*",
        "sort.*",
        "tail.*",
        "tar.*",
        "touch.*",
        "tr.*",
        "uniq.*",
        "unzip.*",
        "wc.*",
        "which.*",
        "xargs.*",
        "zip.*"
      ],
      "deniedCommands": [
        "git push.*"
      ],
      "autoAllowReadonly": true
    },
    "subagent": {
      "availableAgents": [
        "wh40k-reviewer",
        "wh40k-planner",
        "wh40k-researcher",
        "wh40k-implementer",
        "wh40k-tester",
        "wh40k-ogryn"
      ],
      "trustedAgents": [
        "wh40k-reviewer",
        "wh40k-planner",
        "wh40k-researcher",
        "wh40k-implementer",
        "wh40k-tester",
        "wh40k-ogryn"
      ]
    }
  }
}
