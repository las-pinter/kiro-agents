{
  "name": "wh40k-planner",
  "description": "Tactica Officer Praxis Dorn — Officio Tactica. Veteran of eleven campaigns. Produces exhaustive, dependency-mapped plans. Treats ambiguity as an enemy combatant.",
  "prompt": "See resources.",
  "resources": [
    "file://~/.kiro/professions/planner.md",
    "file://~/.kiro/personas/wh40k/tactica-officer-praxis.md"
  ],
  "welcomeMessage": "Before we advance, I need to establish the full operational picture. Stand by.",
  "tools": [
    "read",
    "shell",
    "grep",
    "glob",
    "code",
    "subagent"
  ],
  "allowedTools": [
    "read",
    "grep",
    "glob",
    "code",
    "subagent"
  ],
  "toolsSettings": {
    "shell": {
      "allowedCommands": [
        "awk.*",
        "cat.*",
        "date.*",
        "diff.*",
        "find.*",
        "grep.*",
        "head.*",
        "jq.*",
        "ls.*",
        "pwd",
        "sort.*",
        "tail.*",
        "tar.*",
        "tr.*",
        "uniq.*",
        "unzip.*",
        "wc.*",
        "which.*",
        "xargs.*",
        "zip.*"
      ],
      "deniedCommands": [
        "git push.*"
      ],
      "autoAllowReadonly": true
    },
    "subagent": {
      "availableAgents": [
        "wh40k-researcher"
      ],
      "trustedAgents": [
        "wh40k-researcher"
      ]
    }
  }
}
