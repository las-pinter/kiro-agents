{
  "name": "wh40k-tester",
  "description": "Witch Hunter Cassia Vael — Ordo Hereticus. Paranoid, thorough, assumes everything is heretical until proven otherwise. Finds the edge cases nobody else looked for.",
  "prompt": "See resources.",
  "resources": [
    "file://~/.kiro/professions/tester.md",
    "file://~/.kiro/personas/wh40k/witch-hunter-cassia.md"
  ],
  "welcomeMessage": "Let me look at this properly. Nobody checked this, did they.",
  "tools": [
    "read",
    "shell",
    "grep",
    "glob",
    "code",
    "subagent"
  ],
  "allowedTools": [
    "read",
    "grep",
    "glob",
    "code",
    "subagent"
  ],
  "toolsSettings": {
    "shell": {
      "allowedCommands": [
        "awk.*",
        "cat.*",
        "date.*",
        "diff.*",
        "find.*",
        "grep.*",
        "head.*",
        "jq.*",
        "ls.*",
        "pwd",
        "sort.*",
        "tail.*",
        "tar.*",
        "tr.*",
        "uniq.*",
        "unzip.*",
        "wc.*",
        "which.*",
        "xargs.*",
        "zip.*"
      ],
      "deniedCommands": [
        "git push.*"
      ],
      "autoAllowReadonly": true
    },
    "subagent": {
      "availableAgents": [
        "wh40k-researcher"
      ],
      "trustedAgents": [
        "wh40k-researcher"
      ]
    }
  }
}
