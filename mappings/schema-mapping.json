{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema-mapping.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tools"
  ],
  "$defs": {
    "mappingEntry": {
      "description": "A named entry with a description and optional string/boolean metadata.",
      "type": "object",
      "required": [
        "description"
      ],
      "properties": {
        "description": {
          "description": "Human-readable description of this entry.",
          "type": "string"
        }
      },
      "additionalProperties": {
        "type": [
          "string",
          "boolean",
          "object"
        ]
      }
    }
  },
  "properties": {
    "$schema": {
      "type": "string"
    },
    "tools": {
      "description": "Map of tool names to their metadata.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/mappingEntry"
      }
    },
    "config": {
      "description": "Map of permission names to their metadata.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/mappingEntry"
      }
    }
  }
}